generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  TRADER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum AccountStatus {
  PENDING
  ACTIVE
  PASSED
  FAILED
  SUSPENDED
}

enum TradingPlatform {
  MT4
  MT5
}

enum ChallengeStage {
  PHASE_1
  PHASE_2
  FUNDED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum CouponCategory {
  CHALLENGE
  TOPUP
  ALL
}

enum AffiliateStatus {
  PENDING
  ACTIVE
  PAID
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  PAYOUT
  CHALLENGE
  SUPPORT
}

enum UserApprovalStatus {
  PENDING
  APPROVED
}

enum AuthOtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycDocumentType {
  PICTURE_ID
  PASSPORT
}

enum TopUpStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum TopUpMethod {
  MANUAL
  BANK
  CRYPTO
  CARD
}

enum ManualFundingAccountType {
  CRYPTO
  BANK
  WALLET
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model User {
  id                    String              @id @default(cuid())
  name                  String
  email                 String              @unique
  username              String?             @unique
  passwordHash          String
  phone                 String?             @unique
  country               String?
  avatarUrl             String?
  registrationDeviceId  String?             @unique
  registrationIp        String?
  role                  Role                @default(TRADER)
  status                UserApprovalStatus  @default(PENDING)
  emailVerified         Boolean             @default(false)
  twoFactorEnabled      Boolean             @default(false)
  twoFactorSecret       String?
  twoFactorConfirmedAt  DateTime?
  passwordChangedAt     DateTime?
  payoutHoldUntil       DateTime?
  referralCode          String              @unique
  referredById          String?
  isActive              Boolean             @default(true)
  blockedAt             DateTime?
  blockedUntil          DateTime?
  blockReason           String?
  blockedById           String?
  lastLoginAt           DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  admin                 Admin?
  referredBy            User?               @relation("UserReferrals", fields: [referredById], references: [id])
  referrals             User[]              @relation("UserReferrals")
  orders                Order[]
  payments              Payment[]
  tradingAccounts       TradingAccount[]
  payoutRequests        PayoutRequest[]
  supportTickets        SupportTicket[]
  ticketMessages        TicketMessage[]
  affiliateReferrals    AffiliateReferral[] @relation("AffiliateReferrer")
  affiliateConversions  AffiliateReferral[] @relation("AffiliateReferred")
  notifications         Notification[]
  cmsUpdates            CmsPage[]           @relation("CmsUpdatedBy")
  cmsSectionUpdates     CmsSection[]        @relation("CmsSectionUpdatedBy")
  blogComments          BlogComment[]
  blogReactions         BlogReaction[]
  blogCommentReactions  BlogCommentReaction[]
  activityLogs          ActivityLog[]
  authOtps              AuthOtp[]
  kycSubmissions        KycSubmission[]
  topUpTransactions     TopUpTransaction[]
  twoFactorTrustedDevices TwoFactorTrustedDevice[]
}

model AuthOtp {
  id         String         @id @default(cuid())
  userId     String?
  email      String
  purpose    AuthOtpPurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime       @default(now())
  user       User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose, createdAt])
  @@index([userId, purpose])
}

model TwoFactorTrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  deviceId   String
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([expiresAt])
}

model Admin {
  id          String   @id @default(cuid())
  userId      String   @unique
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminRoleTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String[] @default([])
  locked      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Challenge {
  id                    String           @id @default(cuid())
  name                  String
  slug                  String           @unique
  description           String
  accountSize           Decimal          @db.Decimal(12, 2)
  price                 Decimal          @db.Decimal(10, 2)
  profitTargetPercent   Float
  dailyDrawdownPercent  Float
  maxDrawdownPercent    Float
  minTradingDays        Int
  leverage              String
  phaseCount            Int              @default(2)
  isActive              Boolean          @default(true)
  sortOrder             Int              @default(0)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  orders                Order[]
  tradingAccounts       TradingAccount[]
}

model Order {
  id          String           @id @default(cuid())
  orderNumber String           @unique
  userId      String
  challengeId String
  couponId    String?
  amount      Decimal          @db.Decimal(10, 2)
  discount    Decimal          @default(0) @db.Decimal(10, 2)
  total       Decimal          @db.Decimal(10, 2)
  status      OrderStatus      @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge        @relation(fields: [challengeId], references: [id])
  coupon      Coupon?          @relation(fields: [couponId], references: [id])
  payments    Payment[]
  accounts    TradingAccount[]
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  orderId           String?
  provider          String
  providerPaymentId String?
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order             Order?        @relation(fields: [orderId], references: [id])
}

model TradingAccount {
  id               String          @id @default(cuid())
  userId           String
  challengeId      String
  orderId          String?
  stage            ChallengeStage  @default(PHASE_1)
  platform         TradingPlatform @default(MT5)
  login            String          @unique
  password         String?
  investorPassword String?
  server           String
  serverLink       String?
  statusReason     String?
  balance          Decimal         @default(0) @db.Decimal(12, 2)
  equity           Decimal         @default(0) @db.Decimal(12, 2)
  accountStatus    AccountStatus   @default(PENDING)
  assignedAt       DateTime        @default(now())
  completedAt      DateTime?
  disabledAt       DateTime?
  expiredAt        DateTime?
  passedAt         DateTime?
  failedAt         DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge        Challenge       @relation(fields: [challengeId], references: [id])
  order            Order?          @relation(fields: [orderId], references: [id])
  stats            TradingStats[]
  payoutRequests   PayoutRequest[]
}

model TradingStats {
  id                   String         @id @default(cuid())
  tradingAccountId     String
  recordedAt           DateTime       @default(now())
  balance              Decimal        @db.Decimal(12, 2)
  equity               Decimal        @db.Decimal(12, 2)
  profit               Decimal        @db.Decimal(12, 2)
  dailyDrawdown        Decimal        @db.Decimal(8, 2)
  maxDrawdown          Decimal        @db.Decimal(8, 2)
  profitTargetProgress Float          @default(0)
  openTrades           Int            @default(0)
  closedTrades         Int            @default(0)
  account              TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id               String          @id @default(cuid())
  userId           String
  tradingAccountId String?
  amount           Decimal         @db.Decimal(10, 2)
  method           String
  walletAddress    String?
  bankDetails      String?
  status           PayoutStatus    @default(PENDING)
  adminNote        String?
  certificateUrl   String?
  requestedAt      DateTime        @default(now())
  processedAt      DateTime?
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingAccount   TradingAccount? @relation(fields: [tradingAccountId], references: [id])
}

model TopUpTransaction {
  id                     String                @id @default(cuid())
  userId                 String
  manualFundingAccountId String?
  amount                 Decimal               @db.Decimal(10, 2)
  method                 TopUpMethod           @default(MANUAL)
  status                 TopUpStatus           @default(PENDING)
  reference              String?
  transactionId          String?
  proofUrl               String?
  adminNote              String?
  processedAt            DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  manualFundingAccount   ManualFundingAccount? @relation(fields: [manualFundingAccountId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@index([manualFundingAccountId])
  @@unique([manualFundingAccountId, transactionId])
}

model ManualFundingAccount {
  id                String                   @id @default(cuid())
  label             String
  accountType       ManualFundingAccountType
  asset             String?
  network           String?
  accountIdentifier String
  holderName        String?
  instructions      String?
  imageUrl          String?
  processingTime    String?
  minAmount         Decimal                  @default(0) @db.Decimal(10, 2)
  isActive          Boolean                  @default(true)
  sortOrder         Int                      @default(0)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  topUpTransactions TopUpTransaction[]

  @@index([isActive, sortOrder])
}

model KycSubmission {
  id               String          @id @default(cuid())
  userId           String
  firstName        String
  lastName         String
  middleName       String?
  phone            String
  address          String
  documentType     KycDocumentType
  documentFrontUrl String
  documentBackUrl  String
  status           KycStatus       @default(PENDING)
  acceptedPolicies Boolean         @default(false)
  adminNote        String?
  submittedAt      DateTime        @default(now())
  reviewedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, submittedAt])
  @@index([status])
}

model SupportTicket {
  id        String          @id @default(cuid())
  userId    String
  assignedAdminId String?
  subject   String
  category  String?
  status    TicketStatus    @default(OPEN)
  priority  TicketPriority  @default(MEDIUM)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  TicketMessage[]
}

model TicketMessage {
  id          String        @id @default(cuid())
  ticketId    String
  senderId    String
  message     String
  isStaff     Boolean       @default(false)
  attachments String[]      @default([])
  createdAt   DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User          @relation(fields: [senderId], references: [id])
}

model Coupon {
  id           String       @id @default(cuid())
  code         String       @unique
  description  String?
  category     CouponCategory @default(CHALLENGE)
  discountType DiscountType
  value        Decimal      @db.Decimal(10, 2)
  maxUses      Int?
  usedCount    Int          @default(0)
  startsAt     DateTime?
  expiresAt    DateTime?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  orders       Order[]
}

model AffiliateReferral {
  id               String          @id @default(cuid())
  referrerId       String
  referredUserId   String
  commissionRate   Float           @default(10)
  commissionAmount Decimal         @default(0) @db.Decimal(10, 2)
  status           AffiliateStatus @default(PENDING)
  createdAt        DateTime        @default(now())
  convertedAt      DateTime?
  referrer         User            @relation("AffiliateReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser     User            @relation("AffiliateReferred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredUserId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  archivedAt DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CmsPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  content         String
  metaTitle       String?
  metaDescription String?
  published       Boolean  @default(true)
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sections        CmsSection[]
  updatedBy       User?    @relation("CmsUpdatedBy", fields: [updatedById], references: [id])
}

model CmsSection {
  id            String   @id @default(cuid())
  pageId        String
  pageSlug      String
  sectionKey    String
  label         String
  eyebrow       String?
  title         String
  content       String
  ctaLabel      String?
  ctaHref       String?
  sortOrder     Int      @default(0)
  sectionType   String   @default("block") // block, grid, flex, carousel
  imageUrl      String?
  iconName      String?
  colorScheme   String?
  position      Int      @default(0)
  metadata      Json?
  isVisible     Boolean  @default(true)
  published     Boolean  @default(true)
  updatedById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  page          CmsPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  updatedBy     User?    @relation("CmsSectionUpdatedBy", fields: [updatedById], references: [id])

  @@unique([pageSlug, sectionKey])
  @@index([pageId])
  @@index([pageSlug, sortOrder])
  @@index([published])
}

model Blog {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  shortDescription String
  description      String
  content          String
  category         String?
  tags             String[]      @default([])
  keywords         String[]      @default([])
  status           BlogStatus    @default(DRAFT)
  referenceCtaText String?
  referenceCtaUrl  String?
  seoTitle         String?
  seoDescription   String?
  seoKeywords      String[]      @default([])
  canonicalUrl     String?
  authorName       String?
  viewCount        Int           @default(0)
  publishedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  images           BlogImage[]
  videos           BlogVideo[]
  attachments      BlogAttachment[]
  sections         BlogSection[]
  comments         BlogComment[]
  reactions        BlogReaction[]

  @@index([status, createdAt])
  @@index([category])
}

model BlogImage {
  id       String @id @default(cuid())
  blogId   String
  imageUrl String
  title    String?
  caption  String?
  altText  String?
  order    Int    @default(0)
  blog     Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@index([blogId, order])
}

model BlogVideo {
  id       String @id @default(cuid())
  blogId   String
  videoUrl String
  title    String?
  caption  String?
  order    Int    @default(0)
  blog     Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@index([blogId, order])
}

model BlogAttachment {
  id          String @id @default(cuid())
  blogId      String
  fileUrl     String
  title       String?
  contentType String?
  order       Int    @default(0)
  blog        Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@index([blogId, order])
}

model BlogSection {
  id       String  @id @default(cuid())
  blogId   String
  heading  String
  content  String
  imageUrl String?
  order    Int     @default(0)
  blog     Blog    @relation(fields: [blogId], references: [id], onDelete: Cascade)
  videos   BlogSectionVideo[]

  @@index([blogId, order])
}

model BlogSectionVideo {
  id        String      @id @default(cuid())
  sectionId String
  videoUrl  String
  title     String?
  caption   String?
  order     Int         @default(0)
  section   BlogSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, order])
}

model BlogComment {
  id          String         @id @default(cuid())
  blogId      String
  userId      String
  parentId    String?
  isAnonymous Boolean        @default(false)
  displayName String?
  content     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  blog        Blog           @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      BlogComment?   @relation("BlogCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     BlogComment[]  @relation("BlogCommentReplies")
  images      CommentImage[]
  reactions   BlogCommentReaction[]

  @@index([blogId, createdAt])
  @@index([userId])
  @@index([parentId])
}

model CommentImage {
  id        String      @id @default(cuid())
  commentId String
  imageUrl  String
  comment   BlogComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
}

model BlogReaction {
  id        String   @id @default(cuid())
  blogId    String
  userId    String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([blogId, userId])
  @@index([blogId, type])
  @@index([userId])
}

model BlogCommentReaction {
  id        String      @id @default(cuid())
  commentId String
  userId    String
  type      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  comment   BlogComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId, type])
  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
